# ============================================================
# Polymarket 自动交易系统 - 环境变量配置
# ============================================================
# 复制本文件为 .env 并填入你的真实值
# ⚠️ 永远不要提交 .env 到 Git！
# ============================================================

# -------------------- 钱包配置（必填）--------------------
# 以太坊私钥（0x开头）
# 这是你的资金钥匙，务必保密！
POLYMARKET_PRIVATE_KEY=0x...

# 资金地址（你的钱包地址）
POLYMARKET_FUNDER_ADDRESS=0x...

# 签名类型：
#   0 = EOA (MetaMask/硬件钱包/直接私钥)
#   1 = Email/Magic 登录账户
#   2 = Browser Wallet Proxy
POLYMARKET_SIGNATURE_TYPE=0

# -------------------- API 认证（可选，SDK自动派生）--------------------
# 如果你已有 API Key，可填在这里跳过派生步骤
# 否则留空，系统会自动用私钥派生
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# -------------------- 链配置 --------------------
# Polygon 主网 RPC（可用公共节点或 Alchemy/Infura）
POLYGON_RPC=https://polygon-rpc.com

# -------------------- 通知（可选）--------------------
# Telegram Bot 通知（有交易信号时推送）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# ⚠️ 实盘交易前必读检查清单：
# ============================================================
# 1. 你已在 Polymarket 存入资金（V2 使用 pUSD，非 USDC.e）
# 2. 你已完成 token approvals（USDC/pUSD 和 Conditional Tokens）
# 3. config.yaml 中 dry_run 已改为 false
# 4. 已测试模拟模式至少 24 小时，确认策略逻辑无误
# 5. 你理解风险：可能损失全部本金
# ============================================================
